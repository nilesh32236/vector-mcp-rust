# Vector MCP Rust Configuration

# API and Socket Settings
API_PORT=47821
DATA_DIR=./data

# LLM Configuration
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_DEFAULT_MODEL=gemini-2.5-flash

# Indexing Configuration
PROJECT_ROOT=.
MODEL_NAME=BAAI/bge-small-en-v1.5
EMBEDDER_POOL_SIZE=1

# Watcher
DISABLE_FILE_WATCHER=false

# Feature Toggles (Low-Resource Mode)
ENABLE_LOCAL_LLM=false
ENABLE_LIVE_INDEXING=false

# Force a full re-index on next startup (set to true once, then remove)
# By default the server skips the full scan if the DB already has records.
FORCE_REINDEX=false

# Log file path (default: $DATA_DIR/server.log)
# Monitor with: tail -f ~/.local/share/vector-mcp-rust/server.log | jq .
# LOG_PATH=~/.local/share/vector-mcp-rust/server.log

# KV-cache settings
# KV_CACHE_DIR=~/.local/share/vector-mcp-rust/models/kv_cache
# KV_CACHE_MAX_ENTRIES=10
